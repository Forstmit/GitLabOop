<UserControl x:Class="GitLabOop.Views.OneTimeBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:GitLabOop.Services"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel>
                    <TextBlock Text="{services:Loc OneTimeSectionTitle}"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{services:Loc OneTimeSectionDescription}"
                               Style="{StaticResource InfoTextStyle}" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{services:Loc OneTimeDirectCardTitle}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,18"
                                   Text="{services:Loc OneTimeDirectCardDescription}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="{services:Loc OneTimeDirectTextSourceLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox x:Name="DirectOneTimeText" />

                        <TextBlock Text="{services:Loc OneTimeDirectSliderSourceLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Slider x:Name="DirectOneTimeSlider"
                                Minimum="0"
                                Maximum="100"
                                Value="38" />

                        <Border Style="{StaticResource SummaryBadgeStyle}">
                            <StackPanel>
                                <TextBlock Text="{services:Loc OneTimeDirectSnapshotTitle}"
                                           Style="{StaticResource InputLabelStyle}" />
                                <TextBlock Text="{Binding ElementName=DirectOneTimeText, Path=Text, Mode=OneTime}"
                                           Style="{StaticResource InfoTextStyle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding ElementName=DirectOneTimeSlider, Path=Value, Mode=OneTime, StringFormat={}{0:F0}%}"
                                           Style="{StaticResource InfoTextStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{services:Loc OneTimeViewModelCardTitle}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,18"
                                   Text="{services:Loc OneTimeViewModelCardDescription}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="{services:Loc OneTimeDraftTitleLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding DraftTitle, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{services:Loc OneTimeDraftCommentLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding DraftComment, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{services:Loc OneTimeProgressLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Slider Minimum="0"
                                Maximum="100"
                                Value="{Binding DraftProgress}" />

                        <Button Content="{services:Loc OneTimeRefreshButton}"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding RefreshSnapshotCommand}" />

                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding LastActionMessage}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <ContentControl Margin="0,8,0,0"
                                        Content="{Binding Snapshot}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SummaryBadgeStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{services:Loc OneTimeViewModelSnapshotTitle}"
                                                       Style="{StaticResource InputLabelStyle}" />
                                            <TextBlock Text="{Binding PrimaryText, Mode=OneTime}"
                                                       Style="{StaticResource InfoTextStyle}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding SecondaryText, Mode=OneTime}"
                                                       Style="{StaticResource InfoTextStyle}" />
                                            <ProgressBar Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding NumericValue, Mode=OneTime}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
