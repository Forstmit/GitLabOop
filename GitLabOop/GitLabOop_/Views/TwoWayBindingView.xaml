<UserControl x:Class="GitLabOop.Views.TwoWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:GitLabOop.Services"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel>
                    <TextBlock Text="{services:Loc TwoWaySectionTitle}"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{services:Loc TwoWaySectionDescription}"
                               Style="{StaticResource InfoTextStyle}" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{services:Loc TwoWayDirectCardTitle}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,18"
                                   Text="{services:Loc TwoWayDirectCardDescription}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="{services:Loc TwoWayDirectPrimaryTextLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox x:Name="DirectTwoWaySourceText" />

                        <TextBlock Text="{services:Loc TwoWayDirectMirrorTextLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding ElementName=DirectTwoWaySourceText, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{services:Loc TwoWayDirectSliderSourceLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Slider x:Name="DirectTwoWaySlider"
                                Minimum="0"
                                Maximum="100000"
                                TickFrequency="5000"
                                Value="35000" />

                        <TextBlock Text="{services:Loc TwoWayDirectBudgetTextLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding ElementName=DirectTwoWaySlider, Path=Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F0}}" />

                        <CheckBox x:Name="DirectTwoWayCheckBox"
                                  Content="{services:Loc TwoWayDirectPushCheckbox}"
                                  IsChecked="True" />
                        <ToggleButton Content="{services:Loc TwoWayDirectToggleButton}"
                                      IsChecked="{Binding ElementName=DirectTwoWayCheckBox, Path=IsChecked, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{services:Loc TwoWayViewModelCardTitle}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,18"
                                   Text="{services:Loc TwoWayViewModelCardDescription}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="{services:Loc TwoWayFullNameLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{services:Loc TwoWayFeedbackLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding Feedback, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{services:Loc TwoWayBudgetLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Slider Minimum="0"
                                Maximum="100000"
                                Value="{Binding Budget, Mode=TwoWay}" />
                        <TextBox Text="{Binding Budget, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F0}}" />

                        <CheckBox Content="{services:Loc TwoWayPushCheckbox}"
                                  IsChecked="{Binding PushEnabled, Mode=TwoWay}" />

                        <Border Margin="0,8,0,0"
                                Style="{StaticResource SummaryBadgeStyle}">
                            <TextBlock Text="{Binding LiveSummary}"
                                       Style="{StaticResource InfoTextStyle}" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
