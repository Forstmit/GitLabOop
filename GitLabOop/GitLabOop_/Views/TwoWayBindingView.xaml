<UserControl x:Class="GitLabOop.Views.TwoWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel>
                    <TextBlock Text="Как работает TwoWay"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="При двухсторонней привязке целевой элемент не только получает данные от источника, но и отправляет изменения обратно."
                               Style="{StaticResource InfoTextStyle}" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Прямая двухсторонняя привязка"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,18"
                                   Text="Элементы синхронизируются напрямую через ElementName и явный Mode=TwoWay."
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="Основной текст"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox x:Name="DirectTwoWaySourceText"
                                 Text="Синхронный ввод" />

                        <TextBlock Text="Зеркальный TextBox"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding ElementName=DirectTwoWaySourceText, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Источник: Slider"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Slider x:Name="DirectTwoWaySlider"
                                Minimum="0"
                                Maximum="100000"
                                TickFrequency="5000"
                                Value="35000" />

                        <TextBlock Text="TextBox редактирует тот же источник"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding ElementName=DirectTwoWaySlider, Path=Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F0}}" />

                        <CheckBox x:Name="DirectTwoWayCheckBox"
                                  Content="Флаг отправки включён"
                                  IsChecked="True" />
                        <ToggleButton Content="Повторяет состояние CheckBox"
                                      IsChecked="{Binding ElementName=DirectTwoWayCheckBox, Path=IsChecked, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="TwoWay через ViewModel"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,18"
                                   Text="Все элементы пишут и читают одни и те же свойства ViewModel."
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="ФИО"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Комментарий"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding Feedback, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Бюджет"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Slider Minimum="0"
                                Maximum="100000"
                                Value="{Binding Budget, Mode=TwoWay}" />
                        <TextBox Text="{Binding Budget, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F0}}" />

                        <CheckBox Content="Включить push-уведомления"
                                  IsChecked="{Binding PushEnabled, Mode=TwoWay}" />

                        <Border Margin="0,8,0,0"
                                Style="{StaticResource SummaryBadgeStyle}">
                            <TextBlock Text="{Binding LiveSummary}"
                                       Style="{StaticResource InfoTextStyle}" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
