<UserControl x:Class="GitLabOop.Views.TwoWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_Header]}"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_Description]}"
                               Style="{StaticResource InfoTextStyle}" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_DirectCardTitle]}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,18"
                                   Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_DirectCardDescription]}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_MainTextLabel]}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox x:Name="DirectTwoWaySourceText"
                                 Text="Синхронный ввод" />

                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_MirrorTextLabel]}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding ElementName=DirectTwoWaySourceText, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_SliderSourceLabel]}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Slider x:Name="DirectTwoWaySlider"
                                Minimum="0"
                                Maximum="100000"
                                TickFrequency="5000"
                                Value="35000" />

                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_EditSourceLabel]}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding ElementName=DirectTwoWaySlider, Path=Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F0}}" />

                        <CheckBox x:Name="DirectTwoWayCheckBox"
                                  Content="{Binding Source={StaticResource Loc}, Path=[TwoWay_CheckboxContent]}"
                                  IsChecked="True" />
                        <ToggleButton Content="{Binding Source={StaticResource Loc}, Path=[TwoWay_ToggleContent]}"
                                      IsChecked="{Binding ElementName=DirectTwoWayCheckBox, Path=IsChecked, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_ViewModelCardTitle]}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,18"
                                   Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_ViewModelCardDescription]}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_FullNameLabel]}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_FeedbackLabel]}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding Feedback, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TwoWay_BudgetLabel]}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Slider Minimum="0"
                                Maximum="100000"
                                Value="{Binding Budget, Mode=TwoWay}" />
                        <TextBox Text="{Binding Budget, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F0}}" />

                        <CheckBox Content="{Binding Source={StaticResource Loc}, Path=[TwoWay_PushCheckbox]}"
                                  IsChecked="{Binding PushEnabled, Mode=TwoWay}" />

                        <Border Margin="0,8,0,0"
                                Style="{StaticResource SummaryBadgeStyle}">
                            <TextBlock Text="{Binding LiveSummary}"
                                       Style="{StaticResource InfoTextStyle}" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
