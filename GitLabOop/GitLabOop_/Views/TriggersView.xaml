<UserControl x:Class="GitLabOop.Views.TriggersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Triggers_Header]}"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Margin="0,10,0,12"
                               Text="{Binding Source={StaticResource Loc}, Path=[Triggers_Description]}"
                               Style="{StaticResource InfoTextStyle}" />
                    <WrapPanel>
                        <Button Content="{Binding Source={StaticResource Loc}, Path=[Triggers_ToggleOnline]}"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding ToggleOnlineCommand}" />
                        <Button Content="{Binding Source={StaticResource Loc}, Path=[Triggers_TogglePriority]}"
                                Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding TogglePriorityCommand}" />
                        <Button Content="{Binding Source={StaticResource Loc}, Path=[Triggers_ToggleWarnings]}"
                                Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding ToggleWarningsCommand}" />
                        <Button Content="{Binding Source={StaticResource Loc}, Path=[Triggers_Reset]}"
                                Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding ResetCommand}" />
                    </WrapPanel>
                    <Border Margin="0,14,0,0"
                            Style="{StaticResource SummaryBadgeStyle}">
                        <TextBlock Text="{Binding CurrentState}"
                                   Style="{StaticResource InfoTextStyle}" />
                    </Border>
                </StackPanel>
            </Border>

            <UniformGrid Columns="2" Rows="2">
                <Border Margin="0,0,10,18"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Triggers_TriggerTitle]}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,16"
                                   Text="{Binding Source={StaticResource Loc}, Path=[Triggers_TriggerDescription]}"
                                   Style="{StaticResource InfoTextStyle}" />
                        <Button Content="{Binding Source={StaticResource Loc}, Path=[Triggers_HoverPressButton]}"
                                Padding="18,14"
                                Background="#E2E8F0"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="ButtonRoot"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="18">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ButtonRoot" Property="Background" Value="{StaticResource SecondaryBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="ButtonRoot" Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Margin="10,0,0,18"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Triggers_DataTriggerTitle]}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,16"
                                   Text="{Binding Source={StaticResource Loc}, Path=[Triggers_DataTriggerDescription]}"
                                   Style="{StaticResource InfoTextStyle}" />
                        <Border Padding="16"
                                CornerRadius="18">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E2E8F0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPriorityMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Triggers_PriorityState]}"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPriorityMode}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,10,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Triggers_MultiTriggerTitle]}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,16"
                                   Text="{Binding Source={StaticResource Loc}, Path=[Triggers_MultiTriggerDescription]}"
                                   Style="{StaticResource InfoTextStyle}" />
                        <Button Content="{Binding Source={StaticResource Loc}, Path=[Triggers_HoverAndPressButton]}"
                                Padding="18,14"
                                Background="#E2E8F0"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="StateRoot"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="18">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True" />
                                                            <Condition Property="IsPressed" Value="True" />
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="StateRoot" Property="Background" Value="{StaticResource SecondaryBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Margin="10,0,0,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Triggers_MultiDataTitle]}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,16"
                                   Text="{Binding Source={StaticResource Loc}, Path=[Triggers_MultiDataDescription]}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <Border Padding="16"
                                CornerRadius="18"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform />
                            </Border.RenderTransform>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E2E8F0" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsOnline}" Value="True" />
                                                <Condition Binding="{Binding IsPriorityMode}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{StaticResource SecondarySoftBrush}" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             From="0.9"
                                                             To="1"
                                                             Duration="0:0:0.4" />
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             From="0.9"
                                                             To="1"
                                                             Duration="0:0:0.4" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Triggers_CombinedState]}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
