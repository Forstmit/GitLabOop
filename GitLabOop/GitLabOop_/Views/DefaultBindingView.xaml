<UserControl x:Class="GitLabOop.Views.DefaultBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:GitLabOop.Services"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel>
                    <TextBlock Text="{services:Loc DefaultSectionTitle}"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{services:Loc DefaultSectionDescription}"
                               Style="{StaticResource InfoTextStyle}" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,10,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{services:Loc DefaultDirectCardTitle}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,18"
                                   Text="{services:Loc DefaultDirectCardDescription}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="{services:Loc DefaultDirectSourceSliderLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Slider x:Name="DirectDefaultSlider"
                                Minimum="0"
                                Maximum="100"
                                Value="56" />

                        <TextBlock Text="{services:Loc DefaultDirectTextBoxLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding ElementName=DirectDefaultSlider, Path=Value, StringFormat={}{0:F0}}" />

                        <TextBlock Text="{services:Loc DefaultDirectTextBlockLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBlock Text="{Binding ElementName=DirectDefaultSlider, Path=Value, StringFormat={}{0:F0}%}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="{services:Loc DefaultDirectProgressBarLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{Binding ElementName=DirectDefaultSlider, Path=Value}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{services:Loc DefaultViewModelCardTitle}"
                                   Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Margin="0,8,0,18"
                                   Text="{services:Loc DefaultViewModelCardDescription}"
                                   Style="{StaticResource InfoTextStyle}" />

                        <TextBlock Text="{services:Loc DefaultPresenterNameLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding PresenterName}" />

                        <TextBlock Text="{services:Loc DefaultNotesLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <TextBox Text="{Binding Notes}" />

                        <CheckBox Content="{services:Loc DefaultPinCardCheckbox}"
                                  IsChecked="{Binding IsPinned}" />

                        <TextBlock Text="{services:Loc DefaultAccentOpacityLabel}"
                                   Style="{StaticResource InputLabelStyle}" />
                        <Slider Minimum="10"
                                Maximum="100"
                                Value="{Binding AccentOpacity}" />

                        <Border Height="88"
                                CornerRadius="18"
                                Background="{StaticResource AccentBrush}"
                                Opacity="{Binding AccentOpacityRatio}">
                            <TextBlock VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="{Binding PresenterName}" />
                        </Border>

                        <Border Margin="0,16,0,0"
                                Style="{StaticResource SummaryBadgeStyle}">
                            <TextBlock Text="{Binding Summary}"
                                       Style="{StaticResource InfoTextStyle}" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
