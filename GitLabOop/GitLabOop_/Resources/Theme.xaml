<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="WindowBackgroundBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Offset="0" Color="#0F172A" />
        <GradientStop Offset="0.45" Color="#132238" />
        <GradientStop Offset="1" Color="#1E293B" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PanelBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AccentBrush" Color="#F97316" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#FFF1E8" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="#0F766E" />
    <SolidColorBrush x:Key="SecondarySoftBrush" Color="#E6FFFB" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#D7E2EE" />
    <SolidColorBrush x:Key="TextBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#475569" />
    <SolidColorBrush x:Key="HeroTextBrush" Color="#F8FAFC" />

    <Style x:Key="HeroPanelStyle" TargetType="Border">
        <Setter Property="Padding" Value="28" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#FB923C" />
                    <GradientStop Offset="0.55" Color="#F97316" />
                    <GradientStop Offset="1" Color="#0F766E" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ShellPanelStyle" TargetType="Border">
        <Setter Property="Padding" Value="16" />
        <Setter Property="CornerRadius" Value="26" />
        <Setter Property="Background" Value="#F5F7FB" />
    </Style>

    <Style x:Key="HeroTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource HeroTextBrush}" />
    </Style>

    <Style x:Key="HeroSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="#FDF2F8" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxWidth" Value="860" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style x:Key="InfoTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="MutedCaptionStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#E2E8F0" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="BadgeValueStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SurfaceCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="20" />
        <Setter Property="Margin" Value="0,0,0,18" />
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="22" />
    </Style>

    <Style x:Key="InputLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="Background" Value="#F8FAFC" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1.2" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style TargetType="Slider">
        <Setter Property="Margin" Value="0,0,0,14" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="14" />
        <Setter Property="Margin" Value="0,4,0,14" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Background" Value="#E2E8F0" />
    </Style>

    <Style x:Key="AccentButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SummaryBadgeStyle" TargetType="Border">
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Background" Value="{StaticResource SecondarySoftBrush}" />
    </Style>

    <Style x:Key="ShowcaseTabControlStyle" TargetType="TabControl">
        <Setter Property="Padding" Value="4" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Background" Value="#E2E8F0" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Root"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="16,16,0,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#F8FAFC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
