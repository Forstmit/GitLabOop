<Window x:Class="GitLabOop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:GitLabOop.Views"
        mc:Ignorable="d"
        Title="{Binding Source={StaticResource Loc}, Path=[MainWindow_Title]}"
        Width="1280"
        Height="900"
        MinWidth="1100"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroPanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="370" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,28,0">
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MainWindow_HeroTitle]}"
                               Style="{StaticResource HeroTitleStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding Source={StaticResource Loc}, Path=[MainWindow_HeroSubtitle]}"
                               Style="{StaticResource HeroSubtitleStyle}" />

                    <Border Margin="0,18,0,0"
                            Padding="16,10"
                            HorizontalAlignment="Left"
                            Background="#1FFFFFFF"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MainWindow_ApproachLabel]}"
                                       Style="{StaticResource MutedCaptionStyle}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding Source={StaticResource Loc}, Path=[MainWindow_ApproachValue]}"
                                       Style="{StaticResource BadgeValueStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="22"
                        Background="#16FFFFFF"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MainWindow_LanguageLabel]}"
                                   Style="{StaticResource HeroFormLabelStyle}" />
                        <ComboBox ItemsSource="{Binding SupportedLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  DisplayMemberPath="DisplayName"
                                  Style="{StaticResource HeroComboBoxStyle}" />

                        <Border Margin="0,14,0,0"
                                Style="{StaticResource HeroInfoBadgeStyle}">
                            <TextBlock Text="{Binding CurrentLanguageCaption}"
                                       Style="{StaticResource HeroInfoTextStyle}" />
                        </Border>

                        <Button Margin="0,16,0,0"
                                Content="{Binding Source={StaticResource Loc}, Path=[MainWindow_ShowMessage]}"
                                Command="{Binding ShowLocalizedMessageCommand}"
                                Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Style="{StaticResource ShellPanelStyle}">
            <TabControl Style="{StaticResource ShowcaseTabControlStyle}">
                <TabItem Header="{Binding Source={StaticResource Loc}, Path=[MainWindow_Tab_Default]}">
                    <views:DefaultBindingView DataContext="{Binding DefaultBinding}" />
                </TabItem>
                <TabItem Header="{Binding Source={StaticResource Loc}, Path=[MainWindow_Tab_TwoWay]}">
                    <views:TwoWayBindingView DataContext="{Binding TwoWayBinding}" />
                </TabItem>
                <TabItem Header="{Binding Source={StaticResource Loc}, Path=[MainWindow_Tab_OneTime]}">
                    <views:OneTimeBindingView DataContext="{Binding OneTimeBinding}" />
                </TabItem>
                <TabItem Header="{Binding Source={StaticResource Loc}, Path=[MainWindow_Tab_OneWay]}">
                    <views:OneWayBindingsView DataContext="{Binding OneWayBindings}" />
                </TabItem>
                <TabItem Header="{Binding Source={StaticResource Loc}, Path=[MainWindow_Tab_Triggers]}">
                    <views:TriggersView DataContext="{Binding Triggers}" />
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
