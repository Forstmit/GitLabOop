  </data>
  <data name="OneWaySectionDescription" xml:space="preserve">
    <value>OneWay обновляет только цель из источника, а OneWayToSource работает наоборот: изменения уходят в источник, но исходное значение в контрол не подставляется.</value>
  </data>
  <data name="OneWayDirectCardTitle" xml:space="preserve">
